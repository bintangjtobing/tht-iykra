{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Ops Vision - B Mobile Fund Transfer",
  "uid": "fund-transfer",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Success Rate (1m)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "1 - fund_transfer:failure_ratio:rate1m", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Failure Ratio (1m)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "fund_transfer:failure_ratio:rate1m", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Throughput (req/s)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum(rate(fund_transfer_requests_total[1m]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "p95 Latency (5m)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 1.5 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "fund_transfer:latency_p95:5m", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Transfers by status (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "sum by (status) (rate(fund_transfer_requests_total[1m]))", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failure ratio by region",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        { "expr": "fund_transfer:failure_ratio:rate1m_by_region", "legendFormat": "{{region}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(fund_transfer_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(fund_transfer_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(fund_transfer_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failures by error code (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "expr": "sum by (error_code) (rate(fund_transfer_requests_total{status=\"failed\"}[1m]))", "legendFormat": "{{error_code}}", "refId": "A" }
      ]
    }
  ]
}
